# Use /api when the frontend is served behind nginx (Docker production).
# Use http://localhost:8000/api for standalone Vite dev against a local API.
VITE_API_URL=/api

# Docker dev only: upstream for Vite proxy (service name on compose network).
VITE_DEV_API_PROXY=http://api:8000

# Google Maps — create a key at https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
