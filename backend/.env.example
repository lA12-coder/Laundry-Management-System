# ==============================================================================
# Fua Laundry Platform - Environment Configuration Template
# Duplicate this file as '.env' and populate it with your local/production values.
# Do not commit your actual '.env' file to version control.
# ==============================================================================

# Django Core Settings
SECRET_KEY=your-django-secret-key-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api
FRONT_END_URL=http://localhost:5173

# Database Configuration (use DB_HOST=db when running via root docker-compose)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=db
DB_PORT=5432

# CORS Settings (Comma-separated origins allowed to make API requests)
# Docker production: include http://localhost (nginx on port 80)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173

# Email Configuration
# Use 'django.core.mail.backends.console.EmailBackend' for local testing (prints to terminal)
# Use 'django.core.mail.backends.smtp.EmailBackend' for real email delivery
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-secure-smtp-app-password
DEFAULT_FROM_EMAIL=your-email@example.com
CONTACT_FORM_RECIPIENT=fualaundry16@gmail.com

# Redis Cache & Celery Broker Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Authentication Settings
# Generate a secure secret using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-signing-secret-key-must-be-highly-secure
# Alias supported by settings.py:
# JWT_SIGNING_KEY=your-jwt-signing-secret-key-must-be-highly-secure
JWT_ALGORITHM=HS256
JWT_REFRESH_DAYS=7
JWT_ACCESS_MINUTES=10

# Deploy superuser (Render/Docker — optional)
# Exact names required; creates admin on each deploy and resets password if user exists.
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-strong-password
# Optional:
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_FULL_NAME=System Admin
# DJANGO_SUPERUSER_PHONE_NUMBER=+251900000000