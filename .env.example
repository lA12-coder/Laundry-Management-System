# Root environment for docker compose (optional — backend/.env is the primary API config).
# Copy to .env at repo root: cp .env.example .env

# Published ports
API_PUBLISH_PORT=8000
FRONTEND_PUBLISH_PORT=8080
DB_PUBLISH_PORT=5432
REDIS_PUBLISH_PORT=6379

# Shared with backend/.env — keep DB_* in sync with backend/.env
DB_NAME=fualaundry_db
DB_USER=fua_admin
DB_PASSWORD=changeme

# Frontend build args (production nginx image)
VITE_API_URL=/api
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# URLs for CORS and email links
FRONT_END_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1,api

# Docker DNS workaround (see resolvectl status on Fedora/Linux)
# DOCKER_DNS=10.0.0.1
